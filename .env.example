# ===========================================
# Lead Qualificado — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git.
# ===========================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ---- Meta / Facebook ----
# Access token for Conversions API (server-side only)
META_ACCESS_TOKEN=your_meta_access_token_here

# Pixel ID (also used as Dataset ID for CAPI events)
META_PIXEL_ID=your_pixel_id_here

# Graph API version
META_API_VERSION=v25.0

# Test Event Code (from Events Manager > Test Events)
# Used only in test mode — leave empty for production
META_TEST_EVENT_CODE=TEST12345

# ---- App Config ----
# Environment: local | development | staging | production
NEXT_PUBLIC_APP_ENV=local

# Base URL of the application
NEXT_PUBLIC_APP_URL=http://localhost:3000
